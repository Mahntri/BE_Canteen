generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ================= ENUMS =================
enum DishType {
  NORMAL
  SPECIAL
}

enum DepartmentType {
  UNIT
  GROUP
}

enum GuestType {
  internal
  partner
  visitor
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum VehicleStatus {
  AVAILABLE
  ON_TRIP
  MAINTENANCE
  UNAVAILABLE
}

enum DriverStatus {
  AVAILABLE
  ON_TRIP
  OFF_DUTY
}

enum CarBookingStatus {
  PENDING
  APPROVED
  REJECTED
  ASSIGNED
  ON_TRIP
  COMPLETED
  CANCELLED
  INCIDENT
}

enum CarPriority {
  NORMAL
  HIGH
  URGENT
}

enum ReviewType {
  PERIODIC
  MANUAL
}

enum BookingStatus {
  CONFIRMED
  CANCELLED
  COMPLETED
  REJECTED
}

enum WalletTransactionType {
  DEPOSIT
  PAYMENT
  REFUND
  ADJUST
}

enum WalletTransactionStatus {
  PENDING
  SUCCESS
  FAILED
  CANCELLED
}

enum WarehouseType {
  AMBIENT
  CHILLED
  FROZEN
  NON_FOOD
}

enum EventStatus {
  PLANNED
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum ParticipantStatus {
  INVITED
  ACCEPTED
  DECLINED
}

// ================= MODELS =================

model Organization {
  id                      Int                     @id @default(autoincrement())
  name                    String                  @db.VarChar(150)
  code                    String?                 @unique @db.VarChar(50)
  fullName                String?                 @map("full_name")
  address                 String?
  representative          String?
  phone                   String?                 @db.VarChar(20)
  email                   String?                 @db.VarChar(100)
  logoUrl                 String?                 @map("logo_url")
  defaultBankName         String?                 @map("default_bank_name")
  defaultBankAccount      String?                 @map("default_bank_account")
  defaultAccountName      String?                 @map("default_account_name")
  users                   User[]
  menus                   Menu[]
  departments             Department[]
  setting                 OrganizationSetting?
  reviews                 Review[]
  dishReviews             DishReview[]
  warehouses              Warehouse[]
  events                  Event[]
  vehicles                Vehicle[]
  carBookings             CarBooking[]
  meetingRooms            MeetingRoom[]
  bookingApprovalPolicies BookingApprovalPolicy[]

  @@map("organizations")
}

model OrganizationSetting {
  id                          Int          @id @default(autoincrement())
  orgId                       Int          @unique @map("org_id")
  maxMealPricePerDay          Decimal      @default(35000) @map("max_meal_price_per_day") @db.Decimal(15, 2)
  allowedBookingDaysInAdvance Int          @default(7) @map("allowed_booking_days")
  canBookingOnWeekend         Boolean      @default(false) @map("can_booking_weekend")
  staffBookingDeadlineTime    String       @default("16:00") @map("staff_deadline_time")
  managerBookingDeadlineTime  String       @default("09:00") @map("manager_deadline_time")
  maxDebtAmount               Decimal      @default(500000) @map("max_debt_amount") @db.Decimal(15, 2)
  updatedAt                   DateTime     @updatedAt @map("updated_at")
  organization                Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("organization_settings")
}

model User {
  id                 String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  username           String             @unique @db.VarChar(50)
  employeeCode       String?            @unique @map("employee_code") @db.VarChar(50)
  fullName           String             @map("full_name") @db.VarChar(100)
  email              String?            @unique @db.VarChar(150)
  phoneNumber        String?            @map("phone_number") @db.VarChar(20)
  address            String?            @db.VarChar(255)
  gender             Gender?            @default(OTHER)
  avatarUrl          String?            @map("avatar_url")
  passwordHash       String?            @map("password_hash") @db.VarChar(255)
  departmentId       Int?               @map("department_id")
  roleId             Int?               @map("role_id")
  orgId              Int?               @map("org_id")
  organization       Organization?      @relation(fields: [orgId], references: [id])
  isActive           Boolean?           @default(true) @map("is_active")
  created_at         DateTime?          @default(now()) @db.Timestamp(6)
  jobTitle           String?            @map("job_title")
  dob                DateTime?          @db.Date
  joinDate           DateTime?          @map("join_date") @db.Date
  mobileVersion      String?            @map("mobile_version")
  lastOnline         DateTime?          @map("last_online")
  user_permissions   user_permissions[]
  bookings_user      bookings[]         @relation("bookings_user_idTousers")
  bookings_scanned   bookings[]         @relation("bookings_scanned_byTousers")
  transactions       transactions[]
  department         Department?        @relation(fields: [departmentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  role               Role?              @relation(fields: [roleId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  wallets            wallets?
  reviews            Review[]
  dishReviews        DishReview[]
  managedDepartments Department[]       @relation("DepartmentManager")
  managedWarehouses  Warehouse[]        @relation("WarehouseAccountant")
  createdEvents      Event[]            @relation("EventCreator")
  participatedEvents EventParticipant[]
  driverProfile      Driver?
  createdCarBookings CarBooking[]       @relation("CarBookingCreator")
  carBookingLogs     CarBookingLog[]
  submittedRatings   DriverRating[]
  meetingBookings    MeetingBooking[]
  bookingAuditLogs   BookingAuditLog[]

  @@map("users")
}

model Role {
  id                    Int                    @id @default(autoincrement())
  name                  String                 @unique @db.VarChar(50)
  description           String?
  is_system_role        Boolean?               @default(false)
  role_permissions      role_permissions[]
  subsidies             subsidies[]
  users                 User[]
  bookingRolePermission BookingRolePermission?
  bookingPriorityRule   BookingPriorityRule?

  @@map("roles")
}

model Department {
  id             Int            @id @default(autoincrement())
  orgId          Int            @map("org_id")
  parentId       Int?           @map("parent_id")
  code           String         @db.VarChar(50)
  name           String         @db.VarChar(255)
  isCostCenter   Boolean        @default(false) @map("is_cost_center")
  costCenterCode String?        @map("cost_center_code") @db.VarChar(50)
  type           DepartmentType @default(UNIT)
  bankName       String?        @map("bank_name")
  bankAccount    String?        @map("bank_account")
  purchaseConfig Json?          @map("purchase_config")
  createdAt      DateTime?      @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt      DateTime?      @updatedAt @map("updated_at")
  managerId      String?        @map("manager_id") @db.Uuid
  parent         Department?    @relation("Tree", fields: [parentId], references: [id])
  children       Department[]   @relation("Tree")
  organization   Organization   @relation(fields: [orgId], references: [id])
  users          User[]
  manager        User?          @relation("DepartmentManager", fields: [managerId], references: [id])
  warehouses     Warehouse[]

  @@unique([orgId, code])
  @@map("departments")
}

model permissions {
  id               Int                @id @default(autoincrement())
  code             String             @unique @db.VarChar(100)
  module           String?            @db.VarChar(50)
  description      String?
  role_permissions role_permissions[]
  user_permissions user_permissions[]
}

model role_permissions {
  role_id       Int
  permission_id Int
  permissions   permissions @relation(fields: [permission_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  roles         Role        @relation(fields: [role_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([role_id, permission_id])
}

model user_permissions {
  user_id       String      @db.Uuid
  permission_id Int
  permissions   permissions @relation(fields: [permission_id], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@id([user_id, permission_id])
}

model dishes {
  id            Int             @id @default(autoincrement())
  code          String?         @unique @db.VarChar(50)
  type          DishType        @default(NORMAL)
  name          String          @db.VarChar(150)
  category      String?         @db.VarChar(50)
  description   String?         @db.Text
  instruction   String?         @db.Text
  price         Decimal?        @default(0) @db.Decimal(15, 2)
  costPrice     Decimal?        @default(0) @map("cost_price") @db.Decimal(15, 2)
  image_url     String?
  is_active     Boolean?        @default(true)
  booking_items booking_items[]
  dish_recipes  dish_recipes[]
  menu_items    MenuItem[]
  dish_reviews  DishReview[]

  @@map("dishes")
}

model Review {
  id            Int          @id @default(autoincrement())
  rating        Int
  comment       String?      @db.Text
  isAbnormal    Boolean      @default(false)
  serviceRating Int?         @map("service_rating")
  cleanRating   Int?         @map("clean_rating")
  bookingDate   DateTime?    @map("booking_date") @db.Date
  type          ReviewType   @default(MANUAL)
  userId        String       @db.Uuid
  user          User         @relation(fields: [userId], references: [id])
  orgId         Int
  organization  Organization @relation(fields: [orgId], references: [id])
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  @@index([orgId])
  @@index([isAbnormal])
  @@map("reviews")
}

model DishReview {
  id           Int          @id @default(autoincrement())
  rating       Int
  comment      String?      @db.Text
  isAbnormal   Boolean      @default(false)
  type         ReviewType   @default(MANUAL)
  userId       String       @db.Uuid
  user         User         @relation(fields: [userId], references: [id])
  orgId        Int
  organization Organization @relation(fields: [orgId], references: [id])
  dishId       Int
  dish         dishes       @relation(fields: [dishId], references: [id])
  bookingDate  DateTime     @map("booking_date") @db.Date
  createdAt    DateTime     @default(now()) @map("created_at")

  @@map("dish_reviews")
}

model Ingredient {
  id            Int                          @id @default(autoincrement())
  code          String                       @unique @db.VarChar(50)
  name          String                       @db.VarChar(150)
  price         Decimal                      @default(0) @db.Decimal(15, 2)
  minStockLevel Float                        @map("min_stock_level")
  uomId         Int                          @map("uom_id")
  uom           Uom                          @relation(fields: [uomId], references: [id])
  groupId       Int?                         @map("group_id")
  group         IngredientGroup?             @relation(fields: [groupId], references: [id])
  updatedAt     DateTime                     @updatedAt @map("updated_at")
  createdAt     DateTime?                    @default(now()) @map("created_at")
  deletedAt     DateTime?                    @map("deleted_at")
  dish_recipes  dish_recipes[]
  inventories   Inventory[]
  batches       InventoryBatch[]
  details       InventoryTransactionDetail[]

  @@map("ingredients")
}

model IngredientGroup {
  id          Int          @id @default(autoincrement())
  code        String?      @unique @db.VarChar(50)
  name        String       @db.VarChar(100)
  description String?
  ingredients Ingredient[]

  @@map("ingredient_groups")
}

model dish_recipes {
  dish_id       Int
  ingredient_id Int
  quantity      Decimal    @db.Decimal(10, 4)
  dishes        dishes     @relation(fields: [dish_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  ingredients   Ingredient @relation(fields: [ingredient_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@id([dish_id, ingredient_id])
}

model Uom {
  id          Int          @id @default(autoincrement())
  code        String       @unique @db.VarChar(20)
  name        String       @db.VarChar(50)
  description String?
  ingredients Ingredient[]

  @@map("uoms")
}

model Menu {
  id           Int          @id @default(autoincrement())
  date         DateTime     @unique @db.Date
  orgId        Int          @map("org_id")
  organization Organization @relation(fields: [orgId], references: [id])
  items        MenuItem[]

  @@map("menus")
}

model MenuItem {
  id            Int      @id @default(autoincrement())
  menuId        Int      @map("menu_id")
  dishId        Int      @map("dish_id")
  quantityLimit Int?     @default(0) @map("quantity_limit")
  category      DishType
  menu          Menu     @relation(fields: [menuId], references: [id], onDelete: Cascade)
  dish          dishes   @relation(fields: [dishId], references: [id])

  @@map("menu_items")
}

model bookings {
  id               String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id          String?         @db.Uuid
  code             String?         @unique @map("booking_code") @db.VarChar(50)
  is_guest_booking Boolean?        @default(false)
  guest_name       String?         @db.VarChar(100)
  guest_org        String?         @db.VarChar(150)
  guest_type       GuestType?
  booking_date     DateTime        @db.Date
  shift_id         Int?
  status           BookingStatus?  @default(CONFIRMED)
  note             String?         @db.Text
  totalQuantity    Int             @default(1) @map("total_quantity")
  isPaid           Boolean         @default(false) @map("is_paid")
  is_scanned       Boolean?        @default(false)
  scanned_at       DateTime?       @db.Timestamp(6)
  scanned_by       String?         @db.Uuid
  transaction_id   String?         @map("transaction_id") @db.Uuid
  transaction      transactions?   @relation(fields: [transaction_id], references: [id])
  amount           Decimal?        @default(0) @db.Decimal(15, 2)
  created_at       DateTime?       @default(now()) @db.Timestamp(6)
  booking_items    booking_items[]
  shifts           shifts?         @relation(fields: [shift_id], references: [id])
  scannedBy        User?           @relation("bookings_scanned_byTousers", fields: [scanned_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user             User?           @relation("bookings_user_idTousers", fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([user_id, booking_date, shift_id, guest_name])
}

model booking_items {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  booking_id String?   @db.Uuid
  dish_id    Int?
  quantity   Int?      @default(1)
  unit_price Decimal?  @default(0) @db.Decimal(15, 2)
  bookings   bookings? @relation(fields: [booking_id], references: [id], onDelete: Cascade)
  dishes     dishes?   @relation(fields: [dish_id], references: [id])
}

model shifts {
  id               Int        @id @default(autoincrement())
  name             String     @db.VarChar(50)
  start_time       DateTime   @db.Time(6)
  end_time         DateTime   @db.Time(6)
  booking_deadline DateTime   @db.Time(6)
  bookings         bookings[]
}

model subsidies {
  id               Int      @id @default(autoincrement())
  name             String?  @db.VarChar(100)
  amount           Decimal? @db.Decimal(15, 2)
  apply_to_role_id Int?
  is_active        Boolean? @default(true)
  roles            Role?    @relation(fields: [apply_to_role_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model transactions {
  id               String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  wallet_id        String?                 @db.Uuid
  amount           Decimal                 @db.Decimal(15, 2)
  transaction_type WalletTransactionType?
  status           WalletTransactionStatus @default(SUCCESS)
  description      String?
  evidence_url     String?
  created_by       String?                 @db.Uuid
  created_at       DateTime?               @default(now()) @db.Timestamp(6)
  users            User?                   @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  wallets          wallets?                @relation(fields: [wallet_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction)
  bookings         bookings[]
}

model wallets {
  user_id      String         @id @db.Uuid
  balance      Decimal?       @default(0) @db.Decimal(15, 2)
  last_updated DateTime?      @default(now()) @db.Timestamp(6)
  transactions transactions[]
  users        User           @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model Warehouse {
  id             Int                    @id @default(autoincrement())
  warehouse_code String                 @unique @map("warehouse_code") @db.VarChar(50)
  warehouse_name String                 @map("warehouse_name") @db.VarChar(150)
  location       String?                @db.VarChar(255)
  area           Decimal?               @db.Decimal(10, 2)
  capacity       Int?                   @default(0)
  manager        String?                @db.VarChar(100)
  phone          String?                @db.VarChar(20)
  description    String?                @db.Text
  status         String                 @default("active") @db.VarChar(20)
  type           WarehouseType          @default(AMBIENT)
  departmentId   Int?                   @map("department_id")
  department     Department?            @relation(fields: [departmentId], references: [id])
  accountantId   String?                @map("accountant_id") @db.Uuid
  accountant     User?                  @relation("WarehouseAccountant", fields: [accountantId], references: [id])
  orgId          Int                    @map("org_id")
  organization   Organization           @relation(fields: [orgId], references: [id])
  createdAt      DateTime               @default(now()) @map("created_at")
  updatedAt      DateTime               @updatedAt @map("updated_at")
  inventories    Inventory[]
  batches        InventoryBatch[]
  transactions   InventoryTransaction[]

  @@map("warehouses")
}

model Inventory {
  warehouseId  Int        @map("warehouse_id")
  ingredientId Int        @map("ingredient_id")
  quantity     Decimal    @default(0) @db.Decimal(15, 2)
  minStock     Decimal    @default(0) @map("min_stock")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  warehouse    Warehouse  @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@id([warehouseId, ingredientId])
  @@map("inventories")
}

model InventoryBatch {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  warehouseId  Int        @map("warehouse_id")
  ingredientId Int        @map("ingredient_id")
  batchCode    String     @map("batch_code") @db.VarChar(50)
  quantity     Decimal    @db.Decimal(15, 2)
  importDate   DateTime   @default(now()) @map("import_date")
  expiryDate   DateTime?  @map("expiry_date") @db.Date
  warehouse    Warehouse  @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@map("inventory_batches")
}

model InventoryTransaction {
  id              String                       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code            String                       @unique
  warehouseId     Int                          @map("warehouse_id")
  warehouse       Warehouse                    @relation(fields: [warehouseId], references: [id])
  supplierName    String?                      @map("supplier_name") @db.VarChar(150)
  supplierPhone   String?                      @map("supplier_phone") @db.VarChar(20)
  totalAmount     Decimal?                     @default(0) @map("total_amount") @db.Decimal(15, 2)
  type            String                       @default("IMPORT_PURCHASE")
  status          String                       @default("COMPLETED")
  description     String?
  transactionDate DateTime                     @default(now()) @map("transaction_date")
  details         InventoryTransactionDetail[]

  @@map("inventory_transactions")
}

model InventoryTransactionDetail {
  id            String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  transactionId String               @map("transaction_id") @db.Uuid
  ingredientId  Int                  @map("ingredient_id")
  quantity      Decimal              @db.Decimal(15, 2)
  price         Decimal              @default(0) @db.Decimal(15, 2)
  transaction   InventoryTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  ingredient    Ingredient           @relation(fields: [ingredientId], references: [id])

  @@map("inventory_transaction_details")
}

model Event {
  id           Int                @id @default(autoincrement())
  orgId        Int                @map("org_id")
  name         String             @db.VarChar(200)
  description  String?            @db.Text
  startDate    DateTime           @map("start_date") @db.Timestamp(6)
  endDate      DateTime           @map("end_date") @db.Timestamp(6)
  location     String?            @db.VarChar(255)
  status       EventStatus        @default(PLANNED)
  hasMeal      Boolean            @default(false) @map("has_meal")
  mealBudget   Decimal?           @map("meal_budget") @db.Decimal(15, 2)
  createdBy    String?            @map("created_by") @db.Uuid
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")
  organization Organization       @relation(fields: [orgId], references: [id])
  creator      User?              @relation("EventCreator", fields: [createdBy], references: [id])
  participants EventParticipant[]

  @@map("events")
}

model EventParticipant {
  eventId     Int               @map("event_id")
  userId      String            @map("user_id") @db.Uuid
  status      ParticipantStatus @default(INVITED)
  note        String?
  respondedAt DateTime?         @map("responded_at")
  event       Event             @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([eventId, userId])
  @@map("event_participants")
}

model Vehicle {
  id                  Int               @id @default(autoincrement())
  orgId               Int               @map("org_id")
  code                String            @unique @db.VarChar(20)
  name                String            @db.VarChar(100)
  plateNumber         String            @unique @map("plate_number") @db.VarChar(20)
  type                String            @db.VarChar(50)
  seatCapacity        Int               @map("seat_capacity")
  yearOfManufacture   Int?              @map("year_of_manufacture")
  color               String?           @db.VarChar(30)
  fuelType            String?           @map("fuel_type")
  insuranceExpiry     DateTime?         @map("insurance_expiry") @db.Date
  registrationExpiry  DateTime?         @map("registration_expiry") @db.Date
  lastMaintenanceDate DateTime?         @map("last_maintenance") @db.Date
  nextMaintenanceDate DateTime?         @map("next_maintenance") @db.Date
  status              VehicleStatus     @default(AVAILABLE)
  currentLocation     String?           @map("current_location")
  groupId             Int?              @map("group_id")
  group               VehicleGroup?     @relation(fields: [groupId], references: [id])
  isActive            Boolean           @default(true) @map("is_active")
  deletedAt           DateTime?         @map("deleted_at")
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")
  organization        Organization      @relation(fields: [orgId], references: [id])
  bookings            CarBooking[]
  documents           VehicleDocument[]

  @@map("vehicles")
}

model VehicleGroup {
  id          Int       @id @default(autoincrement())
  orgId       Int       @map("org_id")
  code        String    @db.VarChar(50)
  name        String    @db.VarChar(100)
  description String?
  createdAt   DateTime  @default(now()) @map("created_at")
  vehicles    Vehicle[]

  @@unique([orgId, code])
  @@map("vehicle_groups")
}

model VehicleDocument {
  id         Int       @id @default(autoincrement())
  orgId      Int       @map("org_id")
  vehicleId  Int       @map("vehicle_id")
  vehicle    Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  docType    String    @map("doc_type") @db.VarChar(50)
  title      String?   @db.VarChar(200)
  fileKey    String    @map("file_key") @db.VarChar(255)
  url        String?   @db.VarChar(500)
  issueDate  DateTime? @map("issue_date") @db.Date
  expiryDate DateTime? @map("expiry_date") @db.Date
  note       String?   @db.Text
  createdAt  DateTime  @default(now()) @map("created_at")

  @@map("vehicle_documents")
}

model Driver {
  id                Int            @id @default(autoincrement())
  userId            String         @unique @map("user_id") @db.Uuid
  licenseNumber     String?        @map("license_number") @db.VarChar(50)
  licenseClass      String?        @map("license_class") @db.VarChar(10)
  licenseExpiry     DateTime?      @map("license_expiry") @db.Date
  yearsOfExperience Int?           @default(0) @map("years_of_experience")
  rating            Decimal?       @default(5.0) @db.Decimal(2, 1)
  tripCount         Int            @default(0) @map("trip_count")
  status            DriverStatus   @default(AVAILABLE)
  user              User           @relation(fields: [userId], references: [id])
  bookings          CarBooking[]
  ratings           DriverRating[]

  @@map("drivers")
}

model CarBooking {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code            String           @unique @db.VarChar(20)
  orgId           Int              @map("org_id")
  userId          String           @map("user_id") @db.Uuid
  title           String           @db.VarChar(200)
  leaderName      String?          @map("leader_name") @db.VarChar(100)
  passengerCount  Int              @map("passenger_count")
  startTime       DateTime         @map("start_time") @db.Timestamp(6)
  endTime         DateTime         @map("end_time") @db.Timestamp(6)
  startLocation   String           @map("start_location")
  endLocation     String           @map("end_location")
  waypoints       String?          @db.Text
  note            String?          @db.Text
  priority        CarPriority      @default(NORMAL)
  status          CarBookingStatus @default(PENDING)
  vehicleId       Int?             @map("vehicle_id")
  driverId        Int?             @map("driver_id")
  rejectionReason String?          @map("rejection_reason")
  incidentDetail  String?          @map("incident_detail")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  organization    Organization     @relation(fields: [orgId], references: [id])
  creator         User             @relation("CarBookingCreator", fields: [userId], references: [id])
  vehicle         Vehicle?         @relation(fields: [vehicleId], references: [id])
  driver          Driver?          @relation(fields: [driverId], references: [id])
  logs            CarBookingLog[]
  stops           CarBookingStop[]
  driverRating    DriverRating?

  @@map("car_bookings")
}

model CarBookingLog {
  id        Int        @id @default(autoincrement())
  bookingId String     @map("booking_id") @db.Uuid
  actorId   String     @map("actor_id") @db.Uuid
  action    String
  detail    String?
  timestamp DateTime   @default(now())
  booking   CarBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  actor     User       @relation(fields: [actorId], references: [id])

  @@map("car_booking_logs")
}

model CarBookingStop {
  id        Int        @id @default(autoincrement())
  bookingId String     @map("booking_id") @db.Uuid
  address   String     @db.VarChar(255)
  order     Int
  note      String?    @db.VarChar(255)
  booking   CarBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("car_booking_stops")
}

model DriverRating {
  id Int @id @default(autoincrement())

  bookingId String     @unique @map("booking_id") @db.Uuid
  booking   CarBooking @relation(fields: [bookingId], references: [id])

  driverId Int    @map("driver_id")
  driver   Driver @relation(fields: [driverId], references: [id])

  userId String @map("user_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id])

  attitudeScore       Int @map("attitude_score")
  vehicleQualityScore Int @map("vehicle_quality_score")
  waitTimeScore       Int @map("wait_time_score")
  comfortScore        Int @map("comfort_score")

  score Decimal @db.Decimal(2, 1)

  comment String? @db.Text

  createdAt DateTime @default(now()) @map("created_at")

  @@map("driver_ratings")
}

enum MeetingStatus {
  PENDING
  APPROVED
  CONFIRMED
  REJECTED
  CANCELLED
  COMPLETED
}

model MeetingRoom {
  id       Int     @id @default(autoincrement())
  orgId    Int     @map("org_id")
  name     String  @db.VarChar(100)
  capacity Int     @default(10)
  location String? @db.VarChar(255)
  isActive Boolean @default(true) @map("is_active")

  bookings     MeetingBookingRoom[]
  organization Organization         @relation(fields: [orgId], references: [id])

  @@map("meeting_rooms")
}

model MeetingBooking {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String  @unique @db.VarChar(20)
  title       String  @db.VarChar(255)
  description String? @db.Text

  startTime DateTime @map("start_time") @db.Timestamp(6)
  endTime   DateTime @map("end_time") @db.Timestamp(6)

  organizerId String        @map("organizer_id") @db.Uuid
  status      MeetingStatus @default(CONFIRMED)

  priorityScore Int @default(0) @map("priority_score")

  participantCount Int @default(2) @map("participant_count")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organizer User                 @relation(fields: [organizerId], references: [id])
  rooms     MeetingBookingRoom[]

  @@map("meeting_bookings")
}

model MeetingBookingRoom {
  bookingId String @map("booking_id") @db.Uuid
  roomId    Int    @map("room_id")

  booking MeetingBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  room    MeetingRoom    @relation(fields: [roomId], references: [id], onDelete: Restrict)

  @@id([bookingId, roomId])
  @@map("meeting_booking_rooms")
}

model BookingApprovalPolicy {
  id    Int    @id @default(autoincrement())
  orgId Int    @map("org_id")
  name  String @db.VarChar(100)

  // Điều kiện áp dụng
  isAutoApprove           Boolean @default(false) @map("is_auto_approve")
  requiresManagerApproval Boolean @default(true) @map("requires_manager_approval")

  // Cấu hình linh hoạt (Ví dụ: quy định theo phòng hoặc theo role)
  targetRoleId Int? @map("target_role_id")
  targetRoomId Int? @map("target_room_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id])

  @@map("booking_approval_policies")
}

model BookingRolePermission {
  id     Int @id @default(autoincrement())
  roleId Int @unique @map("role_id")

  canBook           Boolean @default(true) @map("can_book")
  canBypassApproval Boolean @default(false) @map("can_bypass_approval")
  canApproveOthers  Boolean @default(false) @map("can_approve_others")

  // Giới hạn thời gian đặt trước (giờ)
  maxAdvanceHours Int? @map("max_advance_hours")

  role Role @relation(fields: [roleId], references: [id])

  @@map("booking_role_permissions")
}

model BookingPriorityRule {
  id     Int @id @default(autoincrement())
  roleId Int @unique @map("role_id")

  // Trọng số ưu tiên (VD: Chủ tịch: 100, Nhân viên: 10)
  priorityWeight Int @default(0) @map("priority_weight")

  // Quyền chiếm dụng phòng nếu priority cao hơn
  canPreemptLowerPriority Boolean @default(false) @map("can_preempt_lower")

  role Role @relation(fields: [roleId], references: [id])

  @@map("booking_priority_rules")
}

model BookingAuditLog {
  id        Int    @id @default(autoincrement())
  bookingId String @map("booking_id") @db.Uuid
  actorId   String @map("actor_id") @db.Uuid

  action    String // CREATE, APPROVE, REJECT, PREEMPT, CANCEL
  oldStatus String? @map("old_status")
  newStatus String? @map("new_status")

  // Lưu chi tiết thay đổi dưới dạng JSON (Ví dụ: lý do từ chối, hoặc info người bị chiếm phòng)
  payload Json? @db.JsonB

  timestamp DateTime @default(now())

  actor User @relation(fields: [actorId], references: [id])

  @@map("booking_audit_logs")
}
